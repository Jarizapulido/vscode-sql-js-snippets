{
	"JS - Fetch GET": {
		"prefix": "js-fetch-get",
		"body": [
			"fetch('${1:https://api.example.com/data}')",
			"    .then(response => response.json())",
			"    .then(data => ${2:console.log(data)})",
			"    .catch(error => ${3:console.error(error)});"
		],
		"description": "Fetch GET request básico"
	},
	"JS - Fetch GET Async/Await": {
		"prefix": "js-fetch-get-async",
		"body": [
			"const ${1:fetchData} = async () => {",
			"    try {",
			"        const response = await fetch('${2:https://api.example.com/data}');",
			"        const data = await response.json();",
			"        ${3:return data};",
			"    } catch (error) {",
			"        ${4:console.error(error)};",
			"    }",
			"};"
		],
		"description": "Fetch GET con async/await"
	},
