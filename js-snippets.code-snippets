	"JS - Fetch with Error Handling": {
		"prefix": "js-fetch-error",
		"body": [
			"const ${1:fetchData} = async (${2:url}) => {",
			"    const response = await fetch(${2:url});",
			"    if (!response.ok) {",
			"        throw new Error(`HTTP error! status: ${3:response.status}`);",
			"    }",
			"    return await response.json();",
			"};"
		],
		"description": "Fetch con manejo de errores de HTTP"
	},
	"JS - Fetch Abort/Timeout": {
		"prefix": "js-fetch-abort",
		"body": [
			"const ${1:fetchWithTimeout} = async (${2:url}, ${3:timeout} = 5000) => {",
			"    const controller = new AbortController();",
			"    const id = setTimeout(() => controller.abort(), ${3:timeout});",
			"    ",
			"    try {",
			"        const response = await fetch(${2:url}, {",
			"            signal: controller.signal",
			"        });",
			"        clearTimeout(id);",
			"        return await response.json();",
			"    } catch (error) {",
			"        clearTimeout(id);",
			"        throw error;",
			"    }",
			"};"
		],
		"description": "Fetch con timeout y abort"
	},
	"HTML - Formulario básico": {
		"prefix": "html-form",
		"body": [
			"<form id=\"${1:mi-form}\">",
			"    <label>${2:Campo}: <input type=\"${3:text}\" name=\"${4:campo}\" required></label>",
			"    <input type=\"submit\" value=\"${5:Enviar}\">",
			"</form>",
			"<pre id=\"${6:resultado}\"></pre>"
		],
		"description": "HTML formulario básico"
	},
	"JS - Form POST con Fetch": {
		"prefix": "js-form-post",
		"body": [
			"document.getElementById(\"${1:mi-form}\").addEventListener(\"submit\", (e) => {",
			"    e.preventDefault();",
			"    const formData = new FormData(e.target);",
			"    const data = Object.fromEntries(formData);",
			"    fetch(\"${2:/endpoint}\", {",
			"        method: \"POST\",",
			"        headers: { \"Content-Type\": \"application/json\" },",
			"        body: JSON.stringify(data)",
			"    })",
			"    .then(res => res.json())",
			"    .then(result => {",
			"        document.getElementById(\"${3:resultado}\").textContent = JSON.stringify(result);",
			"    });",
			"});"
		],
		"description": "Formulario POST con fetch"
	},
	"JS - Form GET con Fetch": {
		"prefix": "js-form-get",
		"body": [
			"fetch(\"${1:/endpoint}\")",
			"    .then(res => res.json())",
			"    .then(data => {",
			"        document.getElementById(\"${2:resultado}\").textContent = JSON.stringify(data, null, 2);",
			"    });"
		],
		"description": "GET request con fetch"
	},
	"JS - Generar tabla desde JSON": {
		"prefix": "js-table",
		"body": [
			"const data = ${1:[{ campo1: 'dato1', campo2: 'dato2' }]};",
			"const tableBody = document.querySelector(\"#${2:tabla}\");",
			"",
			"data.forEach(item => {",
			"    const tr = document.createElement(\"tr\");",
			"    ",
			"    Object.values(item).forEach(value => {",
			"        const td = document.createElement(\"td\");",
			"        td.textContent = value;",
			"        tr.appendChild(td);",
			"    });",
			"    ",
			"    tableBody.appendChild(tr);",
			"});"
		],
		"description": "Generar tabla desde array de objetos"
	}
}
