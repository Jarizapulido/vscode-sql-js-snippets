	"SQL - PostgreSQL Function Basic": {
		"prefix": "sql-func-pg",
		"body": [
			"CREATE OR REPLACE FUNCTION ${1:function_name}(",
			"    ${2:param1} ${3:INTEGER},",
			"    ${4:param2} ${5:VARCHAR}",
			")",
			"RETURNS ${6:INTEGER} AS $$",
			"BEGIN",
			"    ${7:-- tu lógica aquí}",
			"    RETURN ${8:result};",
			"END;",
			"$$ LANGUAGE plpgsql;"
		],
		"description": "Función PostgreSQL básica"
	},
	"SQL - PostgreSQL Function Return Table": {
		"prefix": "sql-func-pg-table",
		"body": [
			"CREATE OR REPLACE FUNCTION ${1:function_name}(",
			"    ${2:param} ${3:INTEGER}",
			")",
			"RETURNS TABLE(",
			"    ${4:id} INTEGER,",
			"    ${5:name} VARCHAR,",
			"    ${6:created_at} TIMESTAMP",
			") AS $$",
			"BEGIN",
			"    RETURN QUERY",
			"    SELECT ${7:t.id}, ${8:t.name}, ${9:t.created_at}",
			"    FROM ${10:table_name} t",
			"    WHERE ${11:t.id} = $1;",
			"END;",
			"$$ LANGUAGE plpgsql;"
		],
		"description": "Función PostgreSQL que retorna tabla"
	},
	"SQL - PostgreSQL Function Return Set": {
		"prefix": "sql-func-pg-set",
		"body": [
			"CREATE OR REPLACE FUNCTION ${1:function_name}()",
			"RETURNS SETOF ${2:table_name} AS $$",
			"BEGIN",
			"    RETURN QUERY SELECT * FROM ${3:table_name} WHERE ${4:condition};",
			"END;",
			"$$ LANGUAGE plpgsql;"
		],
		"description": "Función PostgreSQL que retorna conjunto de resultados"
	},
