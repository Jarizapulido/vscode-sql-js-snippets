	"SQL - Join with WHERE": {
		"prefix": "sql-join-where",
		"body": [
			"SELECT ${1:a.*}, ${2:b.*}",
			"FROM ${3:table_a} a",
			"INNER JOIN ${4:table_b} b ON ${5:a.id} = ${6:b.id}",
			"WHERE ${7:a.status} = '${8:active}'",
			"ORDER BY ${9:a.created_at} DESC;"
