	"SQL - Many-to-Many Join Query": {
		"prefix": "sql-many-to-many",
		"body": [
			"SELECT",
			"    a.${1:name},",
			"    b.${2:title}",
			"FROM ${3:table_a} a",
			"INNER JOIN ${4:junction_table} j ON a.${5:id} = j.${6:table_a_id}",
			"INNER JOIN ${7:table_b} b ON j.${8:table_b_id} = b.${9:id}",
