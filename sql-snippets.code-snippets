	"SQL - Tabla Intermedia SQLite": {
		"prefix": "sql-junction-sqlite",
		"body": [
			"CREATE TABLE ${1:table_name} (",
			"    ${2:id} INTEGER PRIMARY KEY AUTOINCREMENT,",
			"    ${3:table_a_id} INTEGER NOT NULL,",
			"    ${4:table_b_id} INTEGER NOT NULL,",
			"    ${5:created_at} DATETIME DEFAULT CURRENT_TIMESTAMP,",
			"    FOREIGN KEY (${6:table_a_id}) REFERENCES ${7:table_a}(id),",
			"    FOREIGN KEY (${8:table_b_id}) REFERENCES ${9:table_b}(id),",
			"    UNIQUE(${10:table_a_id}, ${11:table_b_id})",
			");"
		],
		"description": "Tabla intermedia SQLite con Foreign Keys"
	},
